{
  "experiment": "hard_anomaly_v1",
  "description": "Hard anomalies designed for layer-specific detection",
  "anomaly_types": {
    "rule_only": {
      "description": "Structural anomalies with zero electrical impact",
      "examples": [
        "MGM: device type mismatch (breaker vs disconnect) - no voltage effect",
        "TI: disconnected zero-load component - no voltage deviation",
        "Orphan bus: bus with no measurements and no connections"
      ]
    },
    "se_only": {
      "description": "Measurement anomalies invisible to topology",
      "examples": [
        "MTI: correlated bias on voltage measurements (systematic offset)",
        "MTI: gradual drift in measurement calibration",
        "VFC: electrically equivalent connection swap"
      ]
    },
    "gnn_only": {
      "description": "Complex patterns requiring learned representations",
      "examples": [
        "Multi-bus correlated anomalies (2-3 buses simultaneously)",
        "Anomaly patterns that look normal locally but are abnormal globally",
        "Subtle impedance parameter errors affecting power flow distribution"
      ]
    }
  },
